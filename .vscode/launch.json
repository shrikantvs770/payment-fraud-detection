{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run application",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "start"
      ],
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "type": "java",
      "name": "Spring Boot-PaymentGeneratorApplication<payment-generator>",
      "request": "launch",
      "cwd": "${workspaceFolder}",
      "mainClass": "com.srikant.kafka.paymentgenerator.PaymentGeneratorApplication",
      "projectName": "payment-generator",
      "args": "",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}